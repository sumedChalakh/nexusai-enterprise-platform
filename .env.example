# ── App ───────────────────────────────────────────────────────────────────
APP_NAME=NexusAI
DEBUG=true

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_USER=nexusai
POSTGRES_PASSWORD=nexusai123
POSTGRES_DB=nexusai
DB_URL=postgresql://nexusai:nexusai123@postgres:5432/nexusai

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=your-super-secret-key-minimum-32-characters-change-this

# ── Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here    #     

# ── AWS ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
S3_BUCKET=nexusai-docs

# ── Next.js ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=nexusai_chunks
