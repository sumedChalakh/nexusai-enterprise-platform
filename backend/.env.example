# App
DEBUG=true

# Database
DATABASE_URL=postgresql://nexus:nexus@db:5432/nexusai

# JWT
SECRET_KEY=super-secret-dev-key-change-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1
S3_BUCKET=nexusai-documents

# Gemini embeddings (Day 6)
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant (Day 6) — defaults match docker-compose service name
QDRANT_HOST=qdrant
QDRANT_PORT=6333
